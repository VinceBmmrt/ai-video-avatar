# Your Tavus API key. Developer Portal -> API Key -> Create New Key.
TAVUS_API_KEY=

# --- Optional overrides (sensible defaults are used if left unset) ---

# Replica (the face). Default is stock "Anna - Casual" (female). For a male face, e.g. "Lucas - Studio":
#   TAVUS_REPLICA_ID=r5f0577fc829
# In Phase 3, set this to your own trained replica id to make it look like you.
# TAVUS_REPLICA_ID=r90bbd427f71

# Tavus-hosted LLM that powers the conversation.
# TAVUS_LLM_MODEL=tavus-claude-haiku-4.5

# Persona id. Managed automatically: the script creates a persona and writes it here on the first run,
# reuses it afterwards, and rewrites it when you pass --update-persona. No need to set this by hand.
# TAVUS_PERSONA_ID=

# Path to your knowledge file.
# KNOWLEDGE_FILE=knowledge/ME.md

# Max length of a single conversation, in minutes (protects your free minutes).
# DEMO_MAX_MINUTES=5
